APP_NAME=Tron Collector
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# Local minimal mode: SQLite + inline jobs
DATABASE_URL=sqlite:///./tron_collector.db
REDIS_URL=redis://127.0.0.1:6379/0
JOB_EXECUTION_MODE=inline
AUTH_DISABLED=true

JWT_SECRET=replace_with_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password

# Required: 32-byte base64 key from: python backend/scripts/generate_master_key.py
ENCRYPTION_MASTER_KEY=replace_with_32byte_base64

# Strongly recommended in production for stable sync/sweep (avoid 429 limit)
TRONGRID_API_KEY=
TRON_NETWORK=mainnet
USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t

DEFAULT_TRX_RESERVE_SUN=500000
DEFAULT_TRX_MIN_SWEEP_SUN=1000000
DEFAULT_USDT_MIN_SWEEP_RAW=1000000
DEFAULT_USDT_FEE_LIMIT_SUN=20000000
